# LegacyLink Environment Configuration
# Copy to .env and fill in your API keys
# Without API keys, app runs in DEMO MODE with pre-loaded personas

# ============================================
# AI/ML SERVICES (optional - demo works without)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
REPLICATE_API_TOKEN=your_replicate_token_here

# ============================================
# DEMO MODE
# ============================================
# Set to "true" to use pre-loaded personas without API keys
DEMO_MODE=true

# ============================================
# DATABASE (auto-configured by docker-compose)
# ============================================
DATABASE_URL=postgresql://legacylink:legacylink_secret@postgres:5432/legacylink
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_DEMO_MODE=true
